{
  "manifest_version": 3,
  "name": "YouTube Taffy Overlay",
  "description": "Adds a Taffy overlay image to YouTube video thumbnails without replacing the original thumbnails.",
  "version": "1.0.3",
  "permissions": ["storage"],
  "host_permissions": ["https://www.youtube.com/*"],
  "action": {
    "default_title": "Taffy Overlay",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "images/taffy.png",
        "images/assets.json",
        "images/processed/*.png"
      ],
      "matches": ["https://www.youtube.com/*"]
    }
  ]
}
